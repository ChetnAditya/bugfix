generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  TEAMLEAD
  DEVELOPER
  TESTER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Priority {
  P1
  P2
  P3
  P4
}

enum BugStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  FIXED
  VERIFIED
  CLOSED
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  members     User[]
  bugs        Bug[]
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String
  role            Role      @default(TESTER)
  createdAt       DateTime  @default(now())
  teamId          String?
  team            Team?     @relation(fields: [teamId], references: [id])
  directManagerId String?
  directManager   User?     @relation("Manager", fields: [directManagerId], references: [id])
  directReports   User[]    @relation("Manager")
  reportedBugs    Bug[]     @relation("Reporter")
  assignedBugs    Bug[]     @relation("Assignee")
  comments        Comment[]
}

model Bug {
  id               String     @id @default(cuid())
  title            String
  description      String
  stepsToReproduce String
  severity         Severity
  priority         Priority?
  status           BugStatus  @default(NEW)
  screenshots      String[]
  reporterId       String
  assigneeId       String?
  teamId           String?
  reporter         User       @relation("Reporter", fields: [reporterId], references: [id])
  assignee         User?      @relation("Assignee", fields: [assigneeId], references: [id])
  team             Team?      @relation(fields: [teamId], references: [id])
  comments         Comment[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  closedAt         DateTime?

  @@index([status])
  @@index([assigneeId])
  @@index([severity, priority])
  @@index([teamId])
}

model Comment {
  id        String   @id @default(cuid())
  bugId     String
  authorId  String
  text      String
  bug       Bug      @relation(fields: [bugId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
